# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=       # obtained by running setup_google_auth.py once

# Google property IDs
GA4_PROPERTY_ID=properties/XXXXXXXXX
GSC_SITE_URL=https://www.bluemoonwellnessspa.com.au/
GBP_LOCATION_NAME=accounts/XXXXXXXXXX/locations/XXXXXXXXXX

# Facebook / Instagram (from developers.facebook.com)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=       # long-lived Page Access Token
IG_USER_ID=                 # Instagram Business Account ID
